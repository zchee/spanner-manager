	key := spanner.Key{
{{- range .Type.PrimaryKeyFields }}
		{{ .Name | lowerFirst }},
{{- end }}
	}

	cols := {{ .Type.Name}}Columns()

	row, err := db.ReadRow(ctx, "{{ .Type.Table }}", key, cols)
	if err != nil {
		return nil, newError("Find{{ .Type.Name }}", "{{ .Type.Table }}", err)
	}

	decoder := new{{ .Type.Name }}Decoder(cols)
	t, err := decoder(row)
	if err != nil {
		return nil, newErrorWithCode(codes.Internal, "Find{{ .Type.Name }}", "{{ .Type.Table }}", err)
