	excluded := make(map[string]struct{}, len(excludeColumns))
	for _, columnName := range excludeColumns {
		excluded[columnName] = struct{}{}
	}

{{- range .Type.CommitTSFields }}
	if _, skip := excluded["{{ .ColumnName }}"]; !skip {
		t.{{ .Name }} = {{ commitTimestampExpr . }}
	}
{{- end }}
}

