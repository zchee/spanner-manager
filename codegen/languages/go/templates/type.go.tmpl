	return t, nil
}

// Read{{ .Type.Name }} retrieves multiples rows from [{{ .Type.Name }}] by [spanner.KeySet] as a slice.
func Read{{ .Type.Name }}(ctx context.Context, db Reader, keys spanner.KeySet) ([]*{{ .Type.Name }}, error) {
	var res []*{{ .Type.Name }}

	cols := {{ .Type.Name}}Columns()

	decoder := new{{ .Type.Name }}Decoder(cols)
	rows := db.Read(ctx, "{{ .Type.Table }}", keys, cols)
	err := rows.Do(func(row *spanner.Row) error {
		val, err := decoder(row)
		if err != nil {
			return status.Errorf(codes.Internal, "failed to decode {{ .Type.Name }} row: %v", err)
		}
		res = append(res, val)

		return nil
	})
	if err != nil {
		return nil, newError("Read{{ .Type.Name }}", "{{ .Type.Table }}", err)
	}

	return res, nil
}

